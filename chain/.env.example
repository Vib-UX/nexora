# Copy to chain/.env (gitignored). Compose auto-loads this file (it sits
# next to docker-compose.yml) and substitutes ${VAR} references inside
# the explorer-profile services. Every value here also has an inline
# default so the explorer profile boots without this file existing.

# ---- Public URL the explorer is served from ----
# Bake into the frontend bundle at container start. MUST match the host
# nginx site (deploy/vps/nginx/explorer.nexorapq.in.servers.conf).
BLOCKSCOUT_PUBLIC_HOST=explorer.nexorapq.in
BLOCKSCOUT_PUBLIC_PROTOCOL=https
BLOCKSCOUT_PUBLIC_WS_PROTOCOL=wss

# ---- Network identity (header / metadata) ----
BLOCKSCOUT_NETWORK=Nexora
BLOCKSCOUT_SUBNETWORK=Nexora Devnet

# ---- Public RPC the explorer's "Connect wallet" button advertises ----
NEXORA_PUBLIC_RPC_URL=https://blockchain.nexorapq.in

# ---- Image tags ----
# Pin the Elixir backend so `docker compose pull` does not silently
# migrate the database under a fresh schema. Microservices can float on
# `latest` safely.
BLOCKSCOUT_TAG=9.0.2
BLOCKSCOUT_FRONTEND_TAG=latest
BLOCKSCOUT_SIG_PROVIDER_TAG=latest
BLOCKSCOUT_SC_VERIFIER_TAG=latest
BLOCKSCOUT_VISUALIZER_TAG=latest
BLOCKSCOUT_STATS_TAG=latest

# ---- Internal DB passwords ----
# Container-local; never reachable off-host (no published ports). Override
# only if you change the compose to expose the Postgres ports.
# BLOCKSCOUT_DB_PASSWORD=blockscout
# BLOCKSCOUT_STATS_DB_PASSWORD=stats
