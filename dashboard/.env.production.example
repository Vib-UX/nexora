# Copy to .env.production and adjust for your hosted devnet (e.g. blockchain.nexorapq.in).
# Build: these are inlined at `pnpm build` time for client bundles.

NEXT_PUBLIC_NEXORA_RPC_URL=https://blockchain.nexorapq.in
NEXT_PUBLIC_NEXORA_WS_URL=wss://ws.blockchain.nexorapq.in

# Blockscout explorer (additive, see lib/explorer.ts). When set, every
# tx hash / op row in the UI grows a "Blockscout ↗" chip next to the
# existing in-dashboard `trace ↗` link, and the `/tx/[hash]` page gains
# an "Open in Blockscout ↗" pill. The bespoke verifier-aware page stays
# the primary click target.
NEXT_PUBLIC_BLOCKSCOUT_URL=https://explorer.nexorapq.in

# Optional: replace the in-dashboard /tx/[hash] route entirely.
# When set, every `trace ↗` link routes to ${base}/tx/<hash> off-site.
# Leave unset to keep the bespoke verifier-aware page as primary.
# NEXT_PUBLIC_EXPLORER_URL=https://app.nexorapq.in
